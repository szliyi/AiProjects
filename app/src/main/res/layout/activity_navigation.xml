<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- 导航地图 -->
    <com.amap.api.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 模拟导航模式提示 -->
    <LinearLayout
        android:id="@+id/simModeBanner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/bg_sim_banner"
        android:visibility="gone"
        android:elevation="4dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_sim"
            android:contentDescription="模拟" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="模拟导航模式"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvSimSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="2x"
            android:textColor="#FFD54F"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 顶部导航信息面板 -->
    <LinearLayout
        android:id="@+id/topNaviPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:layout_marginHorizontal="16dp"
        android:orientation="vertical"
        android:background="@drawable/bg_navi_panel"
        android:padding="16dp"
        android:elevation="8dp">

        <!-- 下一条指令 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivNextTurn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_turn_right"
                android:contentDescription="转向" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNextRoad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="前方300米右转进入天府大道"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNextDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="300米"
                    android:textColor="#B3FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 剩余信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRemainDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15.2公里"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="剩余距离"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#33FFFFFF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRemainTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28分钟"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="预计到达"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#33FFFFFF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14:45"
                    android:textColor="#FFD54F"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="到达时间"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 底部速度显示 -->
    <LinearLayout
        android:id="@+id/speedPanel"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="120dp"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_speed_circle"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-4dp"
            android:text="km/h"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 底部控制按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btnExitNavi"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_exit"
            android:background="@drawable/bg_navi_control"
            android:contentDescription="退出导航" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnTtsToggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_tts_on"
            android:background="@drawable/bg_navi_control"
            android:contentDescription="语音播报" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnOverview"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_overview"
            android:background="@drawable/bg_navi_control"
            android:contentDescription="总览" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnNightMode"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_night_mode"
            android:background="@drawable/bg_navi_control"
            android:contentDescription="日夜模式" />
    </LinearLayout>

</FrameLayout>
